# Convex deployment (from `npx convex dev`)
CONVEX_DEPLOYMENT=
CONVEX_URL=
CONVEX_SITE_URL=

# Clerk — run `clerk env pull` after linking your app, or copy from the Dashboard
PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk Frontend API URL for Convex JWT validation
# Dashboard → Configure → JWT Templates → Convex integration, or API keys page
CLERK_JWT_ISSUER_DOMAIN=https://your-app.clerk.accounts.dev
