{
  "name": "astro-convex",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "concurrently -n astro,convex -c blue,magenta \"pnpm dev:astro\" \"pnpm dev:convex\"",
    "dev:astro": "node scripts/check-node-version.mjs && cross-env NODE_OPTIONS=--max-http-header-size=65536 astro dev",
    "dev:convex": "convex dev",
    "build": "astro build",
    "preview": "wrangler dev",
    "deploy": "astro build && wrangler deploy",
    "cf-typegen": "wrangler types",
    "format": "prettier --write .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit -p convex/tsconfig.json"
  },
  "engines": {
    "node": ">=22.15.0"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.10",
    "@astrojs/cloudflare": "^13.0.0",
    "@astrojs/react": "^5.0.0",
    "@clerk/astro": "^3.4.10",
    "@clerk/react": "^6.11.1",
    "@clerk/shared": "^4.23.0",
    "@convex-dev/agent": "^0.6.4",
    "@tiptap/extension-image": "^3.27.1",
    "@tiptap/extension-link": "^3.27.1",
    "@tiptap/extension-placeholder": "^3.27.1",
    "@tiptap/pm": "^3.27.1",
    "@tiptap/react": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "ai": "^6.0.35",
    "astro": "^6.4.8",
    "convex": "^1.36.1",
    "convex-helpers": "^0.1.114",
    "openai": "^6.45.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tiptap-markdown": "^0.9.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@convex-dev/eslint-plugin": "^1.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^26.1.0",
    "@typescript-eslint/parser": "^8.62.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.2.2",
    "wrangler": "^4.40.0"
  }
}