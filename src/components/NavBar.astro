---
import {
  Show,
  SignInButton,
  SignUpButton,
  UserButton,
} from "@clerk/astro/components";
import NavLink from "./NavLink.astro";
---

<header class="border-b border-gray-200 bg-white">
  <nav
    class="mx-auto flex max-w-5xl items-center justify-between gap-4 px-4 py-3"
  >
    <a
      href="/"
      class="flex items-center gap-2.5 text-gray-900 transition-opacity hover:opacity-80"
    >
      <img src="/logo.svg" alt="" width="32" height="40" class="h-8 w-auto" />
      <span class="text-lg font-semibold tracking-tight">PILKINGTON</span>
    </a>
    <div class="flex flex-wrap items-center gap-2">
      <NavLink href="/" label="Blog" matchBlog />
      <NavLink href="/assistant" label="Assistant" matchPrefix />
      <NavLink href="/about" label="About" />
      <div class="flex items-center gap-3">
        <Show when="signed-out">
        <SignInButton mode="modal" asChild>
          <button
            type="button"
            class="rounded-md px-3 py-2 text-sm font-medium text-gray-700 transition-colors hover:bg-gray-100"
          >
            Sign in
          </button>
        </SignInButton>
        <SignUpButton mode="modal" asChild>
          <button
            type="button"
            class="rounded-md bg-indigo-600 px-3 py-2 text-sm font-medium text-white transition-colors hover:bg-indigo-700"
          >
            Sign up
          </button>
        </SignUpButton>
        </Show>
        <Show when="signed-in">
          <UserButton />
        </Show>
      </div>
    </div>
  </nav>
</header>
