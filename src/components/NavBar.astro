---
import {
  Show,
  SignInButton,
  SignUpButton,
  UserButton,
} from "@clerk/astro/components";
import {
  accentButtonClass,
  secondaryButtonClass,
} from "../lib/ui.ts";
import BrandLogo from "./BrandLogo.astro";
import NavLink from "./NavLink.astro";
import ThemeToggle from "./ThemeToggle.astro";
---

<header class="border-b border-border bg-surface">
  <nav
    class="mx-auto flex max-w-5xl items-center justify-between gap-4 px-4 py-3"
  >
    <a
      href="/"
      class="flex items-center gap-2.5 text-text transition-opacity hover:opacity-80"
    >
      <BrandLogo />
      <span class="text-lg font-semibold tracking-tight">PILKINGTON</span>
    </a>
    <div class="flex flex-wrap items-center gap-2">
      <NavLink href="/" label="Blog" matchBlog />
      <NavLink href="/assistant" label="Assistant" matchPrefix />
      <NavLink href="/about" label="About" />
      <div class="flex items-center gap-3">
        <ThemeToggle />
        <Show when="signed-out">
        <SignInButton mode="modal" asChild>
          <button type="button" class={secondaryButtonClass}>
            Sign in
          </button>
        </SignInButton>
        <SignUpButton mode="modal" asChild>
          <button type="button" class={accentButtonClass}>
            Sign up
          </button>
        </SignUpButton>
        </Show>
        <Show when="signed-in">
          <UserButton />
        </Show>
      </div>
    </div>
  </nav>
</header>
