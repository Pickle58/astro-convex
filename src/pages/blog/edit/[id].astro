---
export const prerender = false;

import PostEditor from "../../../components/blog/PostEditor.tsx";
import Layout from "../../../layouts/Layout.astro";

const { id } = Astro.params;

// Convex IDs are alphanumeric (base32). Reject obviously malformed values
// early so they don't reach the React island and cause a Convex validation
// error that would crash the component tree.
if (!id || !/^[a-z0-9]+$/i.test(id) || id.length < 10 || id.length > 64) {
  return Astro.redirect("/");
}
---

<Layout title="Edit post">
  <main class="mx-auto max-w-3xl px-4 py-8">
    <PostEditor postId={id} client:only="react" />
  </main>
</Layout>
